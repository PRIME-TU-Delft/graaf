// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
	provider = "prisma-client-js"
}

datasource db {
	provider	= "postgresql"
	url			= env("DATABASE_URL")
}

// START AUTH STUFF

enum UserRole {
	USER
	ADMIN
}

model User {
	id					String		@id @default(cuid())
	role				UserRole	@default(USER)
	nickname			String?
	firstName			String?
	lastName			String?
	email				String		@unique
	emailVerified		DateTime?
	image				String?

	accounts			Account[]
	sessions			Session[]

	program_editors		Program[]	@relation("EditorRelation")
	program_admins		Program[]	@relation("AdminRelation")
	course_editors		Course[]	@relation("EditorRelation")
	course_admins		Course[]	@relation("AdminRelation")

	createdAt			DateTime	@default(now())
	updatedAt			DateTime	@updatedAt
}

model Account {
	userId				String
	type				String
	provider			String
	providerAccountId	String
	refresh_token		String?
	access_token		String?
	expires_at			Int?
	token_type			String?
	scope				String?
	id_token			String?
	session_state		String?

	createdAt			DateTime	@default(now())
	updatedAt			DateTime	@updatedAt

	user				User		@relation(fields: [userId], references: [id], onDelete: Cascade)

	@@id([provider, providerAccountId])
}

model Session {
	sessionToken		String		@unique
	userId				String
	expires				DateTime
	user				User		@relation(fields: [userId], references: [id], onDelete: Cascade)

	createdAt			DateTime	@default(now())
	updatedAt			DateTime	@updatedAt
}

model VerificationToken {
	identifier			String
	token				String
	expires				DateTime

	@@id([identifier, token])
}

// END AUTH STUFF

model Program {
	id				Int			@id @default(autoincrement())
	name			String

	courses			Course[]
	editors			User[]		@relation("EditorRelation")
	admins			User[]		@relation("AdminRelation")

	createdAt		DateTime	@default(now())
	updatedAt		DateTime	@updatedAt
}

enum CourseType {
	COURSE
	SANDBOX
}

model Course {
	id				Int			@id @default(autoincrement())
	code			String		@unique
	type			CourseType	@default(COURSE)
	name			String

	programs		Program[]
	graphs			Graph[]
	links			Link[]
	editors			User[]		@relation("EditorRelation")
	admins			User[]		@relation("AdminRelation")

	createdAt		DateTime	@default(now())
	updatedAt		DateTime	@updatedAt
}

model Graph {
	id				Int			@id @default(autoincrement())
	name			String
	courseId		Int

	course			Course		@relation(fields: [courseId], references: [id])
	domains			Domain[]
	subjects		Subject[]
	lectures		Lecture[]
	links			Link[]

	createdAt		DateTime	@default(now())
	updatedAt		DateTime	@updatedAt
}

enum DomainStyle {
	PROSPEROUS_RED
	ENERGIZING_ORANGE
	SUNNY_YELLOW
	ELECTRIC_GREEN
	CONFIDENT_TURQUOISE
	MYSTERIOUS_BLUE
	MAJESTIC_PURPLE
	POWERFUL_PINK
	NEUTRAL_GRAY
	SERIOUS_BROWN
}

model Domain {
	id				Int			@id @default(autoincrement())
	name			String		@default("")
	style			DomainStyle?
	order			Int
	x				Int			@default(0)
	y				Int			@default(0)
	graphId			Int

	graph			Graph		@relation(fields: [graphId], references: [id], onDelete: Cascade)
	subjects		Subject[]
	parentDomains	Domain[]	@relation("DomainRelation")
	childDomains	Domain[]	@relation("DomainRelation")
}

model Subject {
	id				Int			@id @default(autoincrement())
	name			String		@default("")
	order			Int			@default(-1)
	x				Int			@default(0)
	y				Int			@default(0)
	graphId			Int
	domainId		Int?

	graph			Graph		@relation(fields: [graphId], references: [id], onDelete: Cascade)
	domain			Domain?		@relation(fields: [domainId], references: [id])
	lectures		Lecture[]
	parentSubjects	Subject[]	@relation("SubjectRelation")
	childSubjects	Subject[]	@relation("SubjectRelation")
}

model Lecture {
	id				Int			@id @default(autoincrement())
	name			String		@default("")
	order			Int			@default(-1)
	graphId			Int

	graph			Graph		@relation(fields: [graphId], references: [id], onDelete: Cascade)
	subjects		Subject[]
}

model Link {
	id				Int			@id @default(autoincrement())
	name			String		@default("")
	courseId		Int
	graphId			Int?

	course			Course		@relation(fields: [courseId], references: [id], onDelete: Cascade)
	graph			Graph?		@relation(fields: [graphId], references: [id])
}
