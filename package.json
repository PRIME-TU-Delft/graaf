{
	"name": "graph-editor",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"setup": "./scripts/setup.sh",
		"dev": "vite dev",
		"build": "vite build",
		"build:netlify": "prisma generate && prisma db push --accept-data-loss --force-reset && prisma db seed && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test:integration": "./scripts/run-integration.sh",
		"test": "pnpm run test:unit -- --run",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate dev",
		"prisma:studio": "prisma studio"
	},
	  "engines": {
			"node": ">=24"
		},
		"prisma": {
		"seed": "tsx prisma/seed.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@lucide/svelte": "^1.24.0",
		"@prisma/config": "^7.8.0",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.69.3",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.1",
		"@types/pg": "^8.20.0",
		"@vitest/ui": "4.1.10",
		"autoprefixer": "^10.5.2",
		"bits-ui": "2.18.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.4.2",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"formsnap": "^2.0.1",
		"globals": "^17.7.0",
		"mode-watcher": "^1.1.0",
		"paneforge": "1.0.2",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"prisma": "^7.8.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.2",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.1.4",
		"vitest": "^4.1.10",
		"zod": "^4.4.3"
	},
	"dependencies": {
		"@auth/prisma-adapter": "^2.11.2",
		"@auth/sveltekit": "^1.11.2",
		"@fontsource-variable/noto-sans": "^5.2.10",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tanstack/table-core": "^8.21.3",
		"@thisux/sveltednd": "^0.4.1",
		"@types/d3": "^7.4.3",
		"d3": "^7.9.0",
		"pg": "^8.22.0",
		"screenfull": "^6.0.2",
		"svelte-dnd-action": "^0.9.70",
		"tsx": "^4.23.1"
	}
}
