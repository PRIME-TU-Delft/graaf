		"@types/d3": "^7.4.3",
		"@types/uuid": "^9.0.8",
		"d3": "^7.9.0",
		"dotenv": "^16.4.5",
		"uuid": "^9.0.1"
	},
	"mikro-orm": {
		"alwaysAllowTs": true,
		"configPaths": [
			"./src/lib/server/mikro-orm.config.ts"
		]
	}
