{
	"name": "graph-editor-proposal",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"setup": "./scripts/setup.sh",
		"dev": "vite dev",
		"build": "vite build",
		"build:netlify": "prisma generate && prisma db push --accept-data-loss --force-reset && prisma db seed && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test:integration": "./scripts/run-integration.sh",
		"test": "pnpm run test:unit -- --run",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate dev",
		"prisma:studio": "prisma studio"
	},
	"prisma": {
		"seed": "tsx prisma/seed.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^1.3.2",
		"@eslint/js": "^9.35.0",
		"@internationalized/date": "^3.9.0",
		"@lucide/svelte": "^0.515.0",
		"@sveltejs/adapter-netlify": "^4.4.2",
		"@sveltejs/adapter-node": "^5.3.2",
		"@sveltejs/kit": "^2.38.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.0",
		"@tailwindcss/vite": "^4.1.13",
		"@types/node": "^22.18.1",
		"@vitest/ui": "^3.2.4",
		"autoprefixer": "^10.4.21",
		"bits-ui": "2.8.12",
		"clsx": "^2.1.1",
		"eslint": "^9.35.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.3",
		"formsnap": "^2.0.1",
		"globals": "^15.15.0",
		"lucide-svelte": "^0.469.0",
		"mode-watcher": "^1.1.0",
		"paneforge": "1.0.0-next.5",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"prisma": "^6.16.0",
		"svelte": "^5.38.9",
		"svelte-check": "^4.3.1",
		"svelte-sonner": "^1.0.5",
		"sveltekit-superforms": "^2.27.1",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^1.0.0",
		"tailwindcss": "^4.1.13",
		"tw-animate-css": "^1.3.8",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.43.0",
		"vite": "^7.1.5",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@auth/prisma-adapter": "^2.10.0",
		"@auth/sveltekit": "^1.10.0",
		"@fontsource-variable/noto-sans": "^5.2.8",
		"@prisma/client": "^6.16.0",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.16",
		"@tanstack/table-core": "^8.21.3",
		"@thisux/sveltednd": "^0.0.19",
		"@types/d3": "^7.4.3",
		"d3": "^7.9.0",
		"postgres": "^3.4.7",
		"screenfull": "^6.0.2",
		"svelte-dnd-action": "^0.9.65",
		"tsx": "^4.20.5",
		"valibot": "^1.1.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@prisma/client",
			"@prisma/engines",
			"esbuild",
			"prisma"
		]
	}
}
